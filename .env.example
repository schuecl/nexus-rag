# Copy to .env and adjust if needed. Defaults are dev-only, never use in production.

POSTGRES_USER=nexus_rag
POSTGRES_PASSWORD=nexus_rag
POSTGRES_DB=nexus_rag

# NFR-3: the app and Keycloak get separate, non-superuser database roles --
# POSTGRES_USER above is the bootstrap superuser, used only by
# infra/postgres/init-app-roles.sh (which creates these two roles on first
# boot) and the harden-audit-log one-shot service, never for day-to-day
# traffic. APP_DB_USER connects to the existing POSTGRES_DB database;
# KEYCLOAK_DB_USER gets its own separate KEYCLOAK_DB_NAME database.
APP_DB_USER=nexus_rag_app
APP_DB_PASSWORD=nexus_rag_app
KEYCLOAK_DB_USER=keycloak_app
KEYCLOAK_DB_PASSWORD=keycloak_app
KEYCLOAK_DB_NAME=keycloak

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Embedding model served by Ollama (Section 7.2)
EMBEDDING_MODEL=nomic-embed-text
# Upload size guard in bytes (FR-9/NFR-7), default 50MB.
MAX_UPLOAD_BYTES=52428800
# Chunking target size (words) and overlap ratio (FR-4, Section 2 starting point).
CHUNK_TARGET_WORDS=512
CHUNK_OVERLAP_RATIO=0.15
# Throwaway generation model for exercising LibreChat -> LiteLLM -> Ollama end to end.
# Not a production model choice -- just something small enough to run without a GPU.
GENERATION_MODEL=llama3.2:1b

LITELLM_MASTER_KEY=sk-dev-litellm-master-key

LIBRECHAT_KEYCLOAK_CLIENT_SECRET=dev-librechat-secret
RAG_APP_KEYCLOAK_CLIENT_SECRET=dev-rag-app-secret

# NFR-15: Qdrant requires authenticated access in every environment, including
# dev -- anonymous read/write is never acceptable. QDRANT_API_KEY is full
# read/write (ingestion-worker, which creates the collection and writes new
# points; ingestion-api also holds it to update/delete points on
# approve/reject/supersede); QDRANT_READ_ONLY_API_KEY is read-only
# (orchestration-mcp, which only queries).
QDRANT_API_KEY=dev-qdrant-key
QDRANT_READ_ONLY_API_KEY=dev-qdrant-readonly-key

# NFR-11: durable ingestion job queue (common/job_queue.py). Shared by
# ingestion-api (publishes) and ingestion-worker (consumes) -- both need the
# same token to connect at all.
NATS_AUTH_TOKEN=dev-nats-token
