{
  "realm": "nexus-rag",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 900,
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP", "providerId": "CONFIGURE_TOTP", "enabled": true, "defaultAction": false, "priority": 10, "config": {} },
    { "alias": "TERMS_AND_CONDITIONS", "name": "Terms and Conditions", "providerId": "TERMS_AND_CONDITIONS", "enabled": false, "defaultAction": false, "priority": 20, "config": {} },
    { "alias": "UPDATE_PASSWORD", "name": "Update Password", "providerId": "UPDATE_PASSWORD", "enabled": true, "defaultAction": false, "priority": 30, "config": {} },
    { "alias": "UPDATE_PROFILE", "name": "Update Profile", "providerId": "UPDATE_PROFILE", "enabled": true, "defaultAction": false, "priority": 40, "config": {} },
    { "alias": "VERIFY_EMAIL", "name": "Verify Email", "providerId": "VERIFY_EMAIL", "enabled": true, "defaultAction": false, "priority": 50, "config": {} },
    { "alias": "delete_account", "name": "Delete Account", "providerId": "delete_account", "enabled": false, "defaultAction": false, "priority": 60, "config": {} },
    { "alias": "webauthn-register", "name": "Webauthn Register", "providerId": "webauthn-register", "enabled": true, "defaultAction": false, "priority": 70, "config": {} },
    { "alias": "webauthn-register-passwordless", "name": "Webauthn Register Passwordless", "providerId": "webauthn-register-passwordless", "enabled": true, "defaultAction": false, "priority": 80, "config": {} },
    { "alias": "VERIFY_PROFILE", "name": "Verify Profile", "providerId": "VERIFY_PROFILE", "enabled": true, "defaultAction": false, "priority": 90, "config": {} },
    { "alias": "delete_credential", "name": "Delete Credential", "providerId": "delete_credential", "enabled": true, "defaultAction": false, "priority": 100, "config": {} },
    { "alias": "update_user_locale", "name": "Update User Locale", "providerId": "update_user_locale", "enabled": true, "defaultAction": false, "priority": 1000, "config": {} }
  ],
  "clientScopes": [
    {
      "name": "nexus-rag-claims",
      "protocol": "openid-connect",
      "description": "Claims schema from REQUIREMENTS.md Section 6.2: clearance, releasability, groups, org, rag_roles",
      "protocolMappers": [
        {
          "name": "clearance",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "clearance",
            "claim.name": "clearance",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "releasability",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "releasability",
            "claim.name": "releasability",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "groups-attr",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "groups",
            "claim.name": "groups",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "org",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "org",
            "claim.name": "org",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "rag_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "usermodel.clientRoleMapping.clientId": "rag-app",
            "claim.name": "rag_roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "audience-rag-app",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "rag-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "description": "Standard OIDC profile scope -- explicit because a bare --import-realm doesn't auto-create Keycloak's built-in default scopes; needed for 'preferred_username' to reach a token (referenced by both clients' defaultClientScopes).",
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "description": "Standard OIDC email scope -- same reason as 'profile' above for why this has to be explicit here.",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "rag-app",
      "name": "Nexus RAG API (ingestion-api, orchestration-mcp)",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-rag-app-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["nexus-rag-claims", "profile", "email"],
      "attributes": {
        "standard.token.exchange.enabled": "true"
      }
    },
    {
      "clientId": "librechat",
      "name": "LibreChat (throwaway dev instance)",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-librechat-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://librechat:3080/oauth/openid/callback"],
      "webOrigins": ["http://librechat:3080"],
      "defaultClientScopes": ["nexus-rag-claims", "profile", "email"],
      "attributes": {
        "access.token.lifespan": "900",
        "use.refresh.tokens": "true"
      }
    }
  ],
  "roles": {
    "client": {
      "rag-app": [
        { "name": "rag-ingest", "description": "Can submit documents (FR-1..FR-9)" },
        { "name": "rag-query", "description": "Can query the RAG pipeline (FR-24..FR-29)" },
        { "name": "rag-admin", "description": "Can maintain Classification/Releasability lists (C9)" },
        { "name": "rag-curate:USAREUR-AF", "description": "Curator authority for org USAREUR-AF (FR-12/FR-14)" },
        { "name": "rag-curate:Signal-Corps", "description": "Curator authority for org Signal-Corps (FR-12/FR-14)" }
      ]
    }
  },
  "users": [
    {
      "username": "alice-ingest",
      "email": "alice-ingest@example.mil",
      "firstName": "Alice",
      "lastName": "Ingest",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpass123", "temporary": false }],
      "attributes": {
        "clearance": ["CUI"],
        "releasability": ["REL TO USA/FVEY"],
        "groups": ["USAREUR-AF"],
        "org": ["USAREUR-AF"]
      },
      "clientRoles": { "rag-app": ["rag-ingest"] }
    },
    {
      "username": "bob-query",
      "email": "bob-query@example.mil",
      "firstName": "Bob",
      "lastName": "Query",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpass123", "temporary": false }],
      "attributes": {
        "clearance": ["SECRET"],
        "releasability": ["REL TO USA/FVEY", "REL TO NATO"],
        "groups": ["USAREUR-AF"],
        "org": ["USAREUR-AF"]
      },
      "clientRoles": { "rag-app": ["rag-query"] }
    },
    {
      "username": "carol-curator",
      "email": "carol-curator@example.mil",
      "firstName": "Carol",
      "lastName": "Curator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpass123", "temporary": false }],
      "attributes": {
        "clearance": ["SECRET"],
        "releasability": ["REL TO USA/FVEY", "REL TO NATO"],
        "groups": ["USAREUR-AF"],
        "org": ["USAREUR-AF"]
      },
      "clientRoles": { "rag-app": ["rag-query", "rag-curate:USAREUR-AF"] }
    },
    {
      "username": "dave-admin",
      "email": "dave-admin@example.mil",
      "firstName": "Dave",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "devpass123", "temporary": false }],
      "attributes": {
        "clearance": ["TOP SECRET"],
        "releasability": ["REL TO USA/FVEY", "REL TO NATO", "NOFORN"],
        "groups": ["USAREUR-AF", "Signal-Corps"],
        "org": ["USAREUR-AF"]
      },
      "clientRoles": {
        "rag-app": [
          "rag-ingest",
          "rag-query",
          "rag-admin",
          "rag-curate:USAREUR-AF",
          "rag-curate:Signal-Corps"
        ]
      }
    }
  ]
}
